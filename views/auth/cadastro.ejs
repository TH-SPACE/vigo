<%- include('../partials/head') %>
<button class="tema-btn tema-float" type="button" data-tema-toggle aria-label="Alternar tema claro/escuro" title="Tema claro/escuro">
  <span class="ic-lua">🌙</span><span class="ic-sol">☀️</span>
</button>
<div class="login-wrap">
  <div>
    <div class="login-card">
      <img class="hero" src="/svg/vivo-vivinho-check-purpura-centro-320x320.svg" alt="">
      <h1>Criar conta</h1>
      <p class="sub">Cadastre-se para testar a aplicação</p>

      <%- include('../partials/flash') %>

      <form method="POST" action="/cadastro">
        <div class="form-grupo">
          <label for="nome">Nome completo</label>
          <input type="text" id="nome" name="nome" required autocomplete="name" placeholder="Seu nome">
        </div>
        <div class="form-grupo">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" required autocomplete="username" placeholder="nome@telefonica.com">
        </div>
        <div class="form-grupo">
          <label for="perfil">Perfil para teste</label>
          <select id="perfil" name="perfil">
            <option value="vistoriador">Vistoriador (Supervisor de campo)</option>
            <option value="analista">Analista</option>
          </select>
        </div>
        <div class="form-grupo">
          <label for="senha">Senha <span class="dica">(mín. 6 caracteres)</span></label>
          <input type="password" id="senha" name="senha" minlength="6" required autocomplete="new-password" placeholder="••••••">
        </div>
        <div class="form-grupo">
          <label for="confirmar">Confirmar senha</label>
          <input type="password" id="confirmar" name="confirmar" minlength="6" required autocomplete="new-password" placeholder="••••••">
        </div>
        <button type="submit" class="btn full rosa">Criar conta e entrar</button>
      </form>
      <p class="login-alt">Já tem conta? <a href="/login">Entrar</a></p>
    </div>
    <p class="login-foot center">© <%= new Date().getFullYear() %> · Sistema interno</p>
  </div>
</div>
<script src="/js/app.js?v=<%= assetVer %>"></script>
</body></html>
